{
  "name": "neo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build --mode production",
    "build:prod": "vite build --mode production",
    "deploy:pack": "npm run build:prod && powershell -Command \"Compress-Archive -Path dist\\* -DestinationPath neo-deploy.zip -Force\"",
    "deploy:live": "npm run build:prod && node scripts/copy-live.js",
    "deploy:ftp": "npm run deploy:pack && node scripts/deploy-ftp.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "cap:sync": "npm run build && npx cap sync android",
    "cap:open": "npx cap open android",
    "android:build": "npm run cap:sync && cd android && gradlew.bat assembleDebug",
    "android:build:server": "npm run build && npx cap sync android && cd android && gradlew.bat assembleDebug",
    "android:release": "npm run cap:sync && cd android && gradlew.bat assembleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "firebase": "^12.15.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "basic-ftp": "^6.0.1",
    "dotenv": "^17.4.2",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.12"
  }
}
